{
  "schemaVersion": "calllint.corpus.expected.v1",
  "expectedVerdict": "REVIEW",
  "expectedMaxRiskClass": "S3",
  "allowExtraFindings": true,
  "requiredFindingIds": [{ "id": "action.external-mutation", "minCount": 1 }],
  "forbiddenFindingIds": ["action.financial-observed", "exec.dangerous-command"],
  "requirements": {
    "mustHaveEvidenceForEveryFinding": true,
    "mustHaveFalsePositiveNoteForReviewOrBlock": true,
    "mustHaveRemediationForReviewOrBlock": true
  },
  "dangerousFalseSafePolicy": { "thisCaseMustNeverBeSafe": true }
}
