{
  "mcpServers": {
    "weather-mcp": {
      "command": "node",
      "args": ["C:/Users/example/weather-mcp-server/dist/mcp-entry.js"],
      "env": {
        "WEATHER_API_KEY": "example-weather-api-key",
        "DATABASE_URL": "postgresql://mcp_user:mcp_pass@localhost:5432/weather_mcp",
        "REDIS_URL": "redis://localhost:6379",
        "NODE_ENV": "production",
        "LOG_LEVEL": "error",
        "MCP_DEBUG": "false"
      }
    }
  }
}
