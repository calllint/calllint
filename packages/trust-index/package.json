{
  "name": "@calllint/trust-index",
  "version": "0.1.0",
  "private": true,
  "description": "Phase I ingestion — bakes reproducible, digest-addressed Trust Pages from a fixtures cohort by orchestrating the shipped scan + authority + prepare engines (offline, deterministic, the only scanner; ADR 0046)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "bake": "tsx src/bake.ts",
    "ingest": "tsx src/refreshSnapshot.ts",
    "resolve-evidence": "tsx src/resolveEvidence.ts",
    "verify-claims": "tsx src/verifyClaims.ts"
  },
  "dependencies": {
    "@calllint/config-parser": "workspace:*",
    "@calllint/core": "workspace:*",
    "@calllint/evidence": "workspace:*",
    "@calllint/fingerprint": "workspace:*",
    "@calllint/fixtures": "workspace:*",
    "@calllint/resolver": "workspace:*",
    "@calllint/signature": "workspace:*",
    "@calllint/types": "workspace:*"
  },
  "devDependencies": {}
}
