{
  "name": "calllint-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "brand:assets": "node scripts/generate-brand-assets.mjs",
    "brand:avatars": "node scripts/set-brand-avatars.mjs",
    "build": "pnpm brand:assets && pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json",
    "audit:evidence": "tsx scripts/audit-evidence.ts",
    "audit:coverage": "tsx scripts/coverage-audit.ts",
    "audit:coverage:write": "tsx scripts/coverage-audit.ts --write",
    "audit:calibration": "tsx scripts/calibration-audit.ts",
    "audit:calibration:write": "tsx scripts/calibration-audit.ts --write",
    "audit:calibration:gate": "tsx scripts/calibration-audit.ts --gate",
    "audit:self-claim": "tsx scripts/audit-self-claim-readiness.ts",
    "smoke": "pnpm build && vitest run tests/e2e/test/package-smoke.test.ts",
    "pack:smoke": "node scripts/package-smoke.mjs",
    "pack:smoke:mcp": "node scripts/mcp-pack-smoke.mjs",
    "corpus:test": "node scripts/run-corpus.mjs",
    "corpus:test:verbose": "node scripts/run-corpus.mjs --verbose",
    "corpus:test:case": "node scripts/run-corpus.mjs --case",
    "corpus:test:r2-final": "node scripts/run-corpus.mjs --r2-final",
    "bench:test": "node scripts/run-bench.mjs",
    "bench:test:verbose": "node scripts/run-bench.mjs --verbose",
    "bench:fixtures": "vitest run packages/resolver/test/evidence/benchmark.test.ts",
    "schema:compat": "vitest run tests/schema/schema-compatibility.test.ts packages/evidence/test/model-schema.test.ts packages/telemetry-contract/test/schema.test.ts packages/report-renderer/test/sarif-schema.test.ts tests/readback/manifestSchema.test.ts",
    "agent:smoke": "vitest run apps/cli/test/integrate.test.ts tests/e2e/test/apply-engine.e2e.test.ts tests/e2e/test/auto-discovery.e2e.test.ts tests/invariants/preflight-hook-non-blocking.invariants.test.ts",
    "check:public-copy": "node scripts/check-public-copy.mjs",
    "facts:check": "node scripts/derive-facts.mjs",
    "facts:write": "node scripts/derive-facts.mjs --write",
    "check:telemetry-boundary": "node scripts/check-telemetry-boundary.mjs",
    "bake:trust-index": "pnpm --filter @calllint/trust-index bake",
    "ingest:trust-index": "pnpm --filter @calllint/trust-index ingest",
    "resolve-evidence:trust-index": "pnpm --filter @calllint/trust-index resolve-evidence",
    "verify-claims:trust-index": "pnpm --filter @calllint/trust-index verify-claims",
    "ci:local": "pnpm typecheck && pnpm test && pnpm build && pnpm corpus:test && pnpm bench:test && pnpm check:public-copy && pnpm audit:evidence && pnpm audit:coverage && pnpm audit:calibration"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ajv": "^8.12.0",
    "sharp": "^0.35.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
