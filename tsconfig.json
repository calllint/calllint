{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@calllint/types": ["packages/types/src/index.ts"],
      "@calllint/types/*": ["packages/types/src/*"],
      "@calllint/config-parser": ["packages/config-parser/src/index.ts"],
      "@calllint/resolver": ["packages/resolver/src/index.ts"],
      "@calllint/static-analyzer": ["packages/static-analyzer/src/index.ts"],
      "@calllint/risk-engine": ["packages/risk-engine/src/index.ts"],
      "@calllint/policy": ["packages/policy/src/index.ts"],
      "@calllint/fingerprint": ["packages/fingerprint/src/index.ts"],
      "@calllint/report-renderer": ["packages/report-renderer/src/index.ts"],
      "@calllint/core": ["packages/core/src/index.ts"],
      "@calllint/online": ["packages/online/src/index.ts"],
      "@calllint/fixtures": ["packages/fixtures/src/index.ts"],
      "@calllint/signature": ["packages/signature/src/index.ts"],
      "@calllint/discovery": ["packages/discovery/src/index.ts"],
      "@calllint/evidence": ["packages/evidence/src/index.ts"],
      "@calllint/install-planner": ["packages/install-planner/src/index.ts"],
      "@calllint/flow-analyzer": ["packages/flow-analyzer/src/index.ts"],
      "@calllint/trust-index": ["packages/trust-index/src/index.ts"],
      "@calllint/partner-api": ["packages/partner-api/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "apps/*/src/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
