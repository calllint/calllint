# Baked Trust Page artifacts (Phase I ingestion, ADR 0046) are reproducible,
# byte-exact outputs of `pnpm bake:trust-index`. They must never be line-ending-
# normalized on checkout, or the committed bytes would differ from a fresh emit on
# Windows (CRLF) vs. Linux/macOS (LF) and the reproducibility gate would fail. Pin
# them to LF on every platform so the working tree always matches the emit.
# These are committed under apps/web/public/trust so deploy-web.yml serves them
# same-origin at calllint.com/trust/… (ADR 0046 §4).
apps/web/public/trust/** text eol=lf

# The retained Official MCP Registry snapshot (ADR 0038 §1) is the committed input
# the bake re-runs from. Pin it to LF too so the ingestion input is byte-identical
# across platforms (the reproducibility gate re-bakes from these exact bytes).
packages/trust-index/snapshots/** text eol=lf
