{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://calllint.com/schemas/install-plan.schema.json",
  "title": "CallLint Install Plan (calllint.install-plan.v1)",
  "description": "The exact, reversible change the Trust Gateway would make to a host config, bound to the full upstream digest chain. Pure typed data; generating it writes nothing except (optionally) the plan file. Apply is a separate step (G6). See ADR 0036/0037.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "planId",
    "planDigest",
    "artifactDigest",
    "authorityDigest",
    "decisionDigest",
    "policyDigest",
    "host",
    "tier",
    "operations",
    "rollback",
    "backup",
    "idempotencyKey",
    "expiresAt"
  ],
  "properties": {
    "schema": { "const": "calllint.install-plan.v1" },
    "planId": { "type": "string", "minLength": 1 },
    "planDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "artifactDigest": {
      "oneOf": [{ "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }, { "type": "null" }]
    },
    "authorityDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "decisionDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "policyDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "host": { "type": "string", "minLength": 1 },
    "tier": { "enum": ["A", "B", "C"] },
    "operations": { "type": "array", "items": { "$ref": "#/definitions/operation" } },
    "rollback": { "type": "array", "items": { "$ref": "#/definitions/operation" } },
    "backup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": { "path": { "type": "string" } }
    },
    "idempotencyKey": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "expiresAt": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "target", "preconditionDigest", "patch"],
      "properties": {
        "type": { "const": "json-patch" },
        "target": { "type": "string", "minLength": 1 },
        "preconditionDigest": {
          "oneOf": [
            { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            { "const": "absent" }
          ]
        },
        "patch": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["op", "path"],
            "properties": {
              "op": { "enum": ["add", "remove", "replace", "move", "copy", "test"] },
              "path": { "type": "string" },
              "value": {},
              "from": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
